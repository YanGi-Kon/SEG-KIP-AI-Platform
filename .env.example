# Runtime
NODE_ENV=development
PORT=3000
PUBLIC_BASE_URL=https://your-app.up.railway.app
APP_TIME_ZONE=Asia/Tashkent
CORS_ALLOWED_ORIGINS=https://your-app.up.railway.app

# Feature flags. Keep workspace mode disabled until PostgreSQL and migration checks pass.
WORKSPACE_MODE_ENABLED=false
LEGACY_CONFIG_ENABLED=true
AUTH_REQUIRED=false
OUTBOX_WORKER_ENABLED=false

# PostgreSQL / Railway
DATABASE_URL=
DATABASE_SSL=false
DATABASE_POOL_MAX=10
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_CONNECTION_TIMEOUT_MS=10000
DATABASE_STATEMENT_TIMEOUT_MS=30000

# Platform Google Service Account. Users do not upload this in the new Workspace flow.
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_BASE64=

# Legacy single-workspace fallback only. These are deprecated in multi-workspace mode.
GOOGLE_SPREADSHEET_URL=https://docs.google.com/spreadsheets/d/YOUR_SPREADSHEET_ID/edit
GOOGLE_SHEETS_ID=
SIGNATURE_DRIVE_FOLDER_ID=

# Authentication and encryption. Use independent random values of at least 32 characters.
ACCESS_TOKEN_SECRET=replace-with-a-long-random-access-secret
REFRESH_TOKEN_SECRET=replace-with-a-long-random-refresh-secret
APPROVAL_JWT_SECRET=replace-with-a-long-random-approval-secret
ADMIN_JWT_SECRET=replace-with-a-long-random-admin-secret
WORKSPACE_ENCRYPTION_KEY=replace-with-a-32-byte-workspace-key
APPROVAL_TOKEN_TTL=7d
SIGNATURE_IMAGE_TOKEN_TTL=365d

# Optional legacy administrator login. New Workspace mode will use user accounts and roles.
ADMIN_PASSWORD=

# Gmail SMTP / Nodemailer. Use a Google App Password, not the account password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-account@gmail.com
SMTP_PASS=your-google-app-password
SMTP_FROM=SEG KIP <your-account@gmail.com>

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
