# Existing application settings
PORT=3000
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Google service account used by the application and emailed approval links.
# Paste the complete compact service-account JSON or its base64 encoding in Railway Variables.
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_BASE64=
GOOGLE_SPREADSHEET_URL=https://docs.google.com/spreadsheets/d/YOUR_SPREADSHEET_ID/edit
# Backward-compatible alternative:
GOOGLE_SHEETS_ID=

# Google Drive folder shared with the service-account client_email as Editor.
SIGNATURE_DRIVE_FOLDER_ID=

# Public Railway application URL, without trailing slash.
PUBLIC_BASE_URL=https://your-app.up.railway.app

# At least 32 random characters. Used for approval, CSRF and signature-image tokens.
APPROVAL_JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
APPROVAL_TOKEN_TTL=7d
SIGNATURE_IMAGE_TOKEN_TTL=365d

# Gmail SMTP / Nodemailer. Use a Google App Password, not the account password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-account@gmail.com
SMTP_PASS=your-google-app-password
SMTP_FROM=SEG KIP <your-account@gmail.com>

# Optional admin JWT protection. When ADMIN_PASSWORD is set, signer and send APIs require login.
ADMIN_PASSWORD=
ADMIN_JWT_SECRET=replace-with-another-long-random-secret
